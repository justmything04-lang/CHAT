# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Gemini AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Sheets ────────────────────────────────────────────────────────────
# Paste the ENTIRE contents of credentials.json, then base64-encode it:
#   On Mac/Linux:  base64 -i credentials.json | tr -d '\n'
#   On Windows:    [Convert]::ToBase64String([IO.File]::ReadAllBytes("credentials.json"))
GOOGLE_CREDENTIALS_JSON=base64_encoded_credentials_json_here

# Service-account email from credentials.json  (used to share new sheets)
SHEET_SHARE_EMAIL=your-service-account@project.iam.gserviceaccount.com

# ── Render deployment ────────────────────────────────────────────────────────
# Full Render URL of this service, e.g. https://ai-study-partner.onrender.com
# Leave blank for local polling mode.
RENDER_APP_URL=
