# ════════════════════════════════════════════════════════════════════════════
#  AI Study Partner — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ════════════════════════════════════════════════════════════════════════════

# ── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Free API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model to use. Default: gemini-2.5-flash
# The bot auto-falls-back to other models if this one is retired or rate-limited.
# If you hit 429 / quota errors, try gemini-2.5-flash-lite (higher free RPM),
# or enable billing on your Google Cloud project for much higher limits.
GEMINI_MODEL=gemini-2.5-flash

# ── Google Sheets ─────────────────────────────────────────────────────────────
#
# ⭐ RECOMMENDED for a personal Gmail: OAuth user token.
# A service account has ZERO Drive storage, so it CANNOT create sheets on a
# personal Gmail (storageQuotaExceeded) — and a shared folder does NOT fix that.
# Instead, let the bot use YOUR account: run  python generate_oauth_token.py
# once on your computer, then paste the value it prints here.
GOOGLE_OAUTH_TOKEN=

# ── Service account (ALTERNATIVE to OAuth) ────────────────────────────────────
# Only works for creating sheets on a Google Workspace *Shared Drive*.
# If GOOGLE_OAUTH_TOKEN is set, this is ignored. Base64-encode credentials.json:
#   Linux/Mac: base64 -i credentials.json | tr -d '\n'
#   Windows:   [Convert]::ToBase64String([IO.File]::ReadAllBytes("credentials.json"))
GOOGLE_CREDENTIALS_JSON=

# Optional: a Drive folder ID to keep created sheets tidy. With OAuth this is a
# folder in YOUR Drive; copy the ID from the URL:
#   https://drive.google.com/drive/folders/<THIS_IS_THE_ID>
GDRIVE_FOLDER_ID=

# Optional (service-account mode only): share each sheet to your real Gmail so
# it shows under "Shared with me". Not needed with OAuth — you already own them.
SHEET_SHARE_EMAIL=

# ── Storage backend ───────────────────────────────────────────────────────────
# Options:
#   sqlite    — default, zero-config (file: data/studypartner.db)
#             WARNING: data resets on Render redeploy. Use supabase for production.
#   supabase  — free 500 MB, persistent. Needs SUPABASE_URL + SUPABASE_KEY.
#   gsheet    — uses a Google Sheet as DB. Needs GSHEET_DB_ID. Slow but visual.
STORAGE_BACKEND=sqlite

# Supabase (only if STORAGE_BACKEND=supabase)
# Create a free project at https://supabase.com, run supabase_setup.sql first.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-or-service-role-key

# Google Sheet as DB (only if STORAGE_BACKEND=gsheet)
# GSHEET_DB_ID=your_admin_spreadsheet_id

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Timezone for daily briefing (IANA name). Default: UTC
# Students in India: Asia/Kolkata
TIMEZONE=UTC

# ── Render deployment / 24-7 keep-alive ───────────────────────────────────────
# Full Render service URL. Used by the self-ping that keeps the free instance
# awake 24/7. Leave blank for local runs (self-ping auto-disables).
# Example: https://ai-study-partner.onrender.com
RENDER_APP_URL=

# How often (seconds) to self-ping to stay awake. Render sleeps after ~15 min,
# so keep this under 900. Default 600 (10 min).
KEEP_ALIVE_SECONDS=600

# ── NotebookLM (optional — unofficial library) ────────────────────────────────
# Your Google account used for NotebookLM
# NOTEBOOKLM_GOOGLE_ACCOUNT=your@gmail.com
# NOTEBOOKLM_STORAGE_PATH=./notebooklm_session/

# ── Gamma slides (no API key needed — deep link strategy) ─────────────────────
GAMMA_BASE_URL=https://gamma.app/create
GAMMA_DEFAULT_CARDS=10
